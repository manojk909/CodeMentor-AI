# Core Application Settings
FLASK_ENV=development
SESSION_SECRET=change-this-to-a-secure-random-key-in-production

# Database Settings
# If DATABASE_URL is left empty, the application will automatically fall back
# to a local SQLite database file named 'codementor_ai.db'.
# For PostgreSQL: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=

# AI Provider Keys
# The application prioritizes AI provider keys in the following order:
# 1. OpenAI -> 2. Claude -> 3. Gemini -> 4. OpenRouter -> 5. DeepSeek
# If no key is set, the application uses local sample datasets.
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
